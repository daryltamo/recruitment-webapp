<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail Offre</title>
    <link rel="stylesheet" href="/stylesheets/general.css">
</head>
<body>
    <header>
        <h1>Detail de l'Offre</h1>
    </header>
    <main>
        <div class="offer-details">
            <h2><%= offre.titre %></h2>
            <p><strong>Description:</strong> <%= offre.description %></p>
            <p><strong>Type:</strong> <%= offre.type %></p>
            <p><strong>Lieu:</strong> <%= offre.lieu %></p>
            <p><strong>Date de publication:</strong> <%= offre.datePublication %></p>
            <p><strong>Compétences requises:</strong> <%= offre.competences.join(', ') %></p>
        </div>
        <div class="apply-section">
            <h3>Postuler</h3>
            <form action="/candidature" method="POST">
                <input type="hidden" name="offreId" value="<%= offre._id %>">
                <button type="submit">Envoyer ma candidature</button>
            </form>
        </div>
    </main>
    <footer>
        <p>&copy; 2023 Recrutement Web App</p>
    </footer>
</body>
</html>