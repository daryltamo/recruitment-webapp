<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fiche de Poste</title>
    <link rel="stylesheet" href="/stylesheets/general.css">
</head>
<body>
    <header>
        <h1>Fiche de Poste</h1>
    </header>
    <main>
        <h2><%= poste.titre %></h2>
        <p><strong>Description:</strong> <%= poste.description %></p>
        <p><strong>Compétences requises:</strong> <%= poste.competences.join(', ') %></p>
        <p><strong>Type de contrat:</strong> <%= poste.typeContrat %></p>
        <p><strong>Localisation:</strong> <%= poste.localisation %></p>
        <p><strong>Salaire:</strong> <%= poste.salaire %></p>
    </main>
    <footer>
        <p>&copy; 2023 Votre Entreprise</p>
    </footer>
</body>
</html>