<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Profile</title>
    <link rel="stylesheet" href="/stylesheets/general.css">
</head>
<body>
    <header>
        <h1>User Profile</h1>
    </header>
    <main>
        <h2>Welcome, <%= utilisateur.name %>!</h2>
        <p>Email: <%= utilisateur.email %></p>
        <p>Role: <%= utilisateur.role %></p>
        
        <h3>Your Details:</h3>
        <ul>
            <li>Username: <%= utilisateur.username %></li>
            <li>Joined on: <%= utilisateur.createdAt.toDateString() %></li>
        </ul>

        <a href="/logout">Logout</a>
    </main>
    <footer>
        <p>&copy; 2023 Recruitment Web App</p>
    </footer>
</body>
</html>