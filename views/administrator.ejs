<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administrateur Dashboard</title>
    <link rel="stylesheet" href="/stylesheets/general.css">
</head>
<body>
    <header>
        <h1>Bienvenue sur le tableau de bord Administrateur</h1>
        <nav>
            <ul>
                <li><a href="/admin/gestionOrganisations">Gérer Organisations</a></li>
                <li><a href="/admin/gestionRecruteurs">Gérer Recruteurs</a></li>
                <li><a href="/admin/listeDemandesAjoutOrg">Demandes d'Ajout d'Organisation</a></li>
                <li><a href="/admin/listeDemandesDevenirAdmin">Demandes de Devenir Administrateur</a></li>
                <li><a href="/logout">Déconnexion</a></li>
            </ul>
        </nav>
    </header>
    <main>
        <section>
            <h2>Statistiques</h2>
            <p>Nombre total d'organisations: <%= totalOrganisations %></p>
            <p>Nombre total de recruteurs: <%= totalRecruteurs %></p>
            <p>Nombre total de demandes en attente: <%= totalDemandes %></p>
        </section>
        <section>
            <h2>Dernières Activités</h2>
            <ul>
                <% activites.forEach(function(activite) { %>
                    <li><%= activite.description %> - <%= activite.date %></li>
                <% }); %>
            </ul>
        </section>
    </main>
    <footer>
        <p>&copy; 2023 Votre Application de Recrutement</p>
    </footer>
</body>
</html>