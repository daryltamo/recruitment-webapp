<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recruteur Dashboard</title>
    <link rel="stylesheet" href="/stylesheets/general.css">
    <link rel="stylesheet" href="/stylesheets/accueil.css">
</head>
<body>
    <header>
        <h1>Welcome to the Recruteur Dashboard</h1>
        <nav>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/offres">Manage Job Offers</a></li>
                <li><a href="/candidatures">View Applications</a></li>
                <li><a href="/organisation">Manage Organizations</a></li>
                <li><a href="/logout">Logout</a></li>
            </ul>
        </nav>
    </header>
    <main>
        <section>
            <h2>Your Job Offers</h2>
            <table>
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% jobOffers.forEach(function(offer) { %>
                        <tr>
                            <td><%= offer.title %></td>
                            <td><%= offer.status %></td>
                            <td>
                                <a href="/offres/<%= offer.id %>/edit">Edit</a>
                                <a href="/offres/<%= offer.id %>/delete">Delete</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </section>
        <section>
            <h2>Recent Applications</h2>
            <ul>
                <% applications.forEach(function(application) { %>
                    <li>
                        <strong><%= application.candidateName %></strong> applied for <%= application.jobTitle %>
                        <a href="/candidatures/<%= application.id %>">View Details</a>
                    </li>
                <% }); %>
            </ul>
        </section>
    </main>
    <footer>
        <p>&copy; 2023 Recruitment Platform</p>
    </footer>
</body>
</html>