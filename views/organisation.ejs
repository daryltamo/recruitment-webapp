<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Organisation</title>
    <link rel="stylesheet" href="/stylesheets/general.css">
</head>
<body>
    <header>
        <h1>Organisation Details</h1>
    </header>
    <main>
        <section>
            <h2>Organisation Name: <%= organisation.name %></h2>
            <p>Description: <%= organisation.description %></p>
            <p>Contact: <%= organisation.contact %></p>
        </section>
        <section>
            <h3>Members</h3>
            <ul>
                <% organisation.members.forEach(function(member) { %>
                    <li><%= member.name %> - <%= member.role %></li>
                <% }); %>
            </ul>
        </section>
        <section>
            <h3>Actions</h3>
            <a href="/organisation/edit/<%= organisation.id %>">Edit Organisation</a>
            <form action="/organisation/delete/<%= organisation.id %>" method="POST" style="display:inline;">
                <button type="submit">Delete Organisation</button>
            </form>
        </section>
    </main>
    <footer>
        <p>&copy; 2023 Recruitment Web App</p>
    </footer>
</body>
</html>