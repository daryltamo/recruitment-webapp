<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Offer</title>
    <link rel="stylesheet" href="/stylesheets/general.css">
</head>
<body>
    <header>
        <h1>Job Offer Details</h1>
    </header>
    <main>
        <section>
            <h2><%= offre.titre %></h2>
            <p><strong>Description:</strong> <%= offre.description %></p>
            <p><strong>Location:</strong> <%= offre.localisation %></p>
            <p><strong>Salary:</strong> <%= offre.salaire %></p>
            <p><strong>Posted on:</strong> <%= offre.datePublication %></p>
        </section>
        <section>
            <h3>Apply for this job</h3>
            <form action="/candidature" method="POST">
                <input type="hidden" name="offreId" value="<%= offre._id %>">
                <label for="nom">Name:</label>
                <input type="text" id="nom" name="nom" required>
                <label for="email">Email:</label>
                <input type="email" id="email" name="email" required>
                <button type="submit">Submit Application</button>
            </form>
        </section>
    </main>
    <footer>
        <p>&copy; 2023 Recruitment Platform</p>
    </footer>
</body>
</html>